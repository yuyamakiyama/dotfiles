autoload -Uz compinit add-zsh-hook
compinit

eval "$(fnm env --use-on-cd --shell zsh)"
eval "$(pyenv init -)"
eval "$(ssh-agent -s)"

# Prompt
setopt PROMPT_SUBST

_prompt_precmd() {
  local git=''
  local branch=$(command git symbolic-ref --short HEAD 2>/dev/null)
  if [[ -n $branch ]]; then
    local dirty
    [[ -n $(command git status --porcelain 2>/dev/null | head -1) ]] && dirty='*'
    git="%F{242}${branch}%F{218}${dirty}%f"
  fi
  print
  PROMPT="%F{blue}%~%f ${git}
%(?.%F{magenta}.%F{red})❯%f "
}
add-zsh-hook precmd _prompt_precmd

# Completion
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# History substring search
source $(brew --prefix)/share/zsh-history-substring-search/zsh-history-substring-search.zsh
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

source $(brew --prefix)/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOME/.zsh/configs/alias.zsh
source $HOME/.zsh/configs/work.zsh
source $HOME/.zsh/configs/git.zsh
source $HOME/.zsh/configs/fzf.zsh
source $HOME/.zsh/configs/bindkey.zsh
source $HOME/.bun/_bun
source $HOME/google-cloud-sdk/path.zsh.inc
source $HOME/google-cloud-sdk/completion.zsh.inc
source $HOME/.local/bin/env

export HISTFILE=$HOME/.zsh/.zsh_history
export HISTSIZE=100000
export SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_DUPS

export PATH="$PATH:/usr/local/bin"
export PATH=$PATH:"$HOME/google-cloud-sdk/bin"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
export PYENV_ROOT="$HOME/.pyenv"
export PATH="/opt/homebrew/opt/openjdk@17/bin:$PATH"
export BUM_INSTALL="$HOME/.bum"
export PATH="$BUM_INSTALL/bin:$PATH"
export JAVA_HOME="/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home"
export ANDROID_HOME="$HOME/Library/Android/sdk"
export PATH="$PATH:$ANDROID_HOME/emulator"
export PATH="$PATH:$ANDROID_HOME/platform-tools"

command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
