autoload -Uz compinit add-zsh-hook
compinit

export EDITOR=nvim
export VISUAL=nvim

eval "$(fnm env --use-on-cd --shell zsh)"
eval "$(pyenv init -)"

# Reuse existing ssh-agent if available
if [[ -z "$SSH_AUTH_SOCK" ]] || ! ssh-add -l &>/dev/null; then
  eval "$(ssh-agent -s)"
fi

# Prompt
setopt PROMPT_SUBST

# Async git status — prompt renders instantly, dirty/ahead/behind appear when ready
_git_prompt=''
_git_branch=''
_git_async_pid=0

_prompt_async_git_status() {
  local output_file="/tmp/zsh_git_async_$$"
  # Kill previous async job if still running
  if (( _git_async_pid > 0 )); then
    kill $_git_async_pid 2>/dev/null
    _git_async_pid=0
  fi
  (
    local result=''
    # Dirty check
    if [[ -n $(command git status --porcelain 2>/dev/null | head -1) ]]; then
      result='*'
    fi
    # Ahead/behind check
    local counts=$(command git rev-list --count --left-right HEAD...@{upstream} 2>/dev/null)
    if [[ -n $counts ]]; then
      local ahead=${counts%%	*}
      local behind=${counts##*	}
      (( ahead > 0 )) && result="${result} ↑"
      (( behind > 0 )) && result="${result} ↓"
    fi
    echo "$result" > "$output_file"
    kill -USR1 $$ 2>/dev/null
  ) &!
  _git_async_pid=$!
}

TRAPUSR1() {
  local output_file="/tmp/zsh_git_async_$$"
  if [[ -f "$output_file" ]]; then
    local result=$(<"$output_file")
    rm -f "$output_file"
    _git_async_pid=0
    # Update _git_prompt with async result so reset-prompt picks it up
    if [[ -n $_git_branch ]]; then
      _git_prompt="%F{242}${_git_branch}%F{218}${result}%f"
    fi
    zle && zle reset-prompt
  fi
}

_prompt_precmd() {
  local new_branch=$(command git symbolic-ref --short HEAD 2>/dev/null)
  if [[ -n $new_branch ]]; then
    # Only reset prompt when branch changes; otherwise keep previous async result
    if [[ "$new_branch" != "$_git_branch" ]]; then
      _git_prompt="%F{242}${new_branch}%f"
    fi
    _git_branch=$new_branch
    _prompt_async_git_status
  else
    _git_branch=''
    _git_prompt=''
  fi
  print
}
# Single quotes: PROMPT_SUBST evaluates $_git_prompt at display time, not assignment time
PROMPT='%F{blue}%~%f ${_git_prompt}
%(?.%F{magenta}.%F{red})❯%f '
add-zsh-hook precmd _prompt_precmd

# Completion
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'

# Cache brew prefix
_brew_prefix=/opt/homebrew

# History substring search
source $_brew_prefix/share/zsh-history-substring-search/zsh-history-substring-search.zsh
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

source $_brew_prefix/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source $_brew_prefix/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source $HOME/.zsh/configs/alias.zsh
source $HOME/.zsh/configs/work.zsh
source $HOME/.zsh/configs/git.zsh
source $HOME/.zsh/configs/fzf.zsh
source $HOME/.zsh/configs/bindkey.zsh
source $HOME/.bun/_bun
source $HOME/google-cloud-sdk/path.zsh.inc
source $HOME/google-cloud-sdk/completion.zsh.inc
source $HOME/.local/bin/env

export HISTFILE=$HOME/.zsh/.zsh_history
export HISTSIZE=100000
export SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_DUPS

export EDITOR=nvim
export VISUAL=nvim
export PATH="$PATH:/usr/local/bin"
export PATH=$PATH:"$HOME/google-cloud-sdk/bin"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
export PYENV_ROOT="$HOME/.pyenv"
export PATH="/opt/homebrew/opt/openjdk@17/bin:$PATH"
export BUM_INSTALL="$HOME/.bum"
export PATH="$BUM_INSTALL/bin:$PATH"
export JAVA_HOME="/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home"
export ANDROID_HOME="$HOME/Library/Android/sdk"
export PATH="$PATH:$ANDROID_HOME/emulator"
export PATH="$PATH:$ANDROID_HOME/platform-tools"

command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
